{
  "global": {
    "color": {
      "white": {
        "$type": "color",
        "$value": "#ffffff"
      },
      "black": {
        "$type": "color",
        "$value": "#000000"
      },
      "navy": {
        "$type": "color",
        "$value": "#040e4b",
        "$description": "Brand navy"
      },
      "navy-light": {
        "$type": "color",
        "$value": "#06187a",
        "$description": "Navy hover state"
      },
      "red": {
        "$type": "color",
        "$value": "#dd3039",
        "$description": "Brand red"
      },
      "grey": {
        "$type": "color",
        "$value": "#aeaebc",
        "$description": "Brand grey"
      },
      "grey-light": {
        "$type": "color",
        "$value": "#dddddd",
        "$description": "Light grey border"
      },
      "grey-dark": {
        "$type": "color",
        "$value": "#666666",
        "$description": "Muted text"
      },
      "grey-darker": {
        "$type": "color",
        "$value": "#202020",
        "$description": "Secondary text"
      },
      "grey-muted": {
        "$type": "color",
        "$value": "#999999",
        "$description": "Placeholder text"
      },
      "grey-surface": {
        "$type": "color",
        "$value": "#f4f4f4",
        "$description": "Light surface"
      },
      "grey-text": {
        "$type": "color",
        "$value": "#333333",
        "$description": "Body text on light sections"
      }
    },
    "fontFamily": {
      "sans": {
        "$type": "fontFamily",
        "$value": "Proxima Nova",
        "$description": "Primary typeface (Adobe Typekit kit: yna8sgw)"
      },
      "fallback": {
        "$type": "fontFamily",
        "$value": "Arial"
      }
    },
    "fontWeight": {
      "regular": {
        "$type": "fontWeight",
        "$value": "Regular",
        "$description": "400 — body, H1, H2"
      },
      "semibold": {
        "$type": "fontWeight",
        "$value": "Semi Bold",
        "$description": "600"
      },
      "bold": {
        "$type": "fontWeight",
        "$value": "Bold",
        "$description": "700 — H3–H6, buttons, labels"
      }
    },
    "fontSize": {
      "body-m": {
        "$type": "dimension",
        "$value": "16",
        "$description": "Default body"
      },
      "body-s": {
        "$type": "dimension",
        "$value": "14",
        "$description": "Small body / code"
      },
      "body-xs": {
        "$type": "dimension",
        "$value": "13",
        "$description": "Extra small"
      },
      "heading-xxl-mobile": {
        "$type": "dimension",
        "$value": "36",
        "$description": "H1 mobile"
      },
      "heading-xl-mobile": {
        "$type": "dimension",
        "$value": "32",
        "$description": "H2 mobile"
      },
      "heading-l-mobile": {
        "$type": "dimension",
        "$value": "24",
        "$description": "H3 mobile"
      },
      "heading-m-mobile": {
        "$type": "dimension",
        "$value": "20",
        "$description": "H4 mobile"
      },
      "heading-s": {
        "$type": "dimension",
        "$value": "18",
        "$description": "H5"
      },
      "heading-xs": {
        "$type": "dimension",
        "$value": "16",
        "$description": "H6"
      },
      "heading-xxl-desktop": {
        "$type": "dimension",
        "$value": "44",
        "$description": "H1 desktop (≥900px)"
      },
      "heading-xl-desktop": {
        "$type": "dimension",
        "$value": "44",
        "$description": "H2 desktop (≥900px)"
      },
      "heading-l-desktop": {
        "$type": "dimension",
        "$value": "28",
        "$description": "H3 desktop (≥900px)"
      },
      "heading-m-desktop": {
        "$type": "dimension",
        "$value": "24",
        "$description": "H4 desktop (≥900px)"
      },
      "display-large": {
        "$type": "dimension",
        "$value": "52",
        "$description": "Dark section display heading"
      },
      "display-body": {
        "$type": "dimension",
        "$value": "21",
        "$description": "Dark section body text"
      }
    },
    "lineHeight": {
      "body": {
        "$type": "number",
        "$value": "125%",
        "$description": "1.25"
      },
      "heading-tight": {
        "$type": "number",
        "$value": "91%",
        "$description": "0.91 — headings"
      },
      "heading-relaxed": {
        "$type": "number",
        "$value": "150%",
        "$description": "1.5 — H6"
      },
      "button": {
        "$type": "number",
        "$value": "100%",
        "$description": "1"
      },
      "display-large": {
        "$type": "dimension",
        "$value": "56",
        "$description": "Display heading"
      },
      "display-body": {
        "$type": "dimension",
        "$value": "24",
        "$description": "Display body"
      }
    },
    "spacing": {
      "xs": { "$type": "dimension", "$value": "8" },
      "s": { "$type": "dimension", "$value": "16" },
      "m": { "$type": "dimension", "$value": "24" },
      "l": { "$type": "dimension", "$value": "40" },
      "xl": { "$type": "dimension", "$value": "64" },
      "xxl": { "$type": "dimension", "$value": "80" }
    },
    "borderRadius": {
      "pill": { "$type": "dimension", "$value": "16", "$description": "Buttons" },
      "sm": { "$type": "dimension", "$value": "2", "$description": "Form inputs" },
      "md": { "$type": "dimension", "$value": "8", "$description": "Code blocks, cards" }
    },
    "borderWidth": {
      "thin": { "$type": "dimension", "$value": "1" },
      "medium": { "$type": "dimension", "$value": "2" },
      "thick": { "$type": "dimension", "$value": "3", "$description": "Blockquote border" }
    },
    "shadow": {
      "sm": {
        "$type": "boxShadow",
        "$value": { "x": "0", "y": "1", "blur": "3", "spread": "0", "color": "rgba(0, 0, 0, 0.10)", "type": "dropShadow" }
      },
      "md": {
        "$type": "boxShadow",
        "$value": { "x": "0", "y": "4", "blur": "12", "spread": "0", "color": "rgba(0, 0, 0, 0.15)", "type": "dropShadow" }
      }
    },
    "sizing": {
      "content-max-width": { "$type": "dimension", "$value": "1440", "$description": "Maximum content width" },
      "nav-height-mobile": { "$type": "dimension", "$value": "64", "$description": "Nav height mobile" },
      "nav-height-desktop": { "$type": "dimension", "$value": "80", "$description": "Nav height desktop (≥900px)" }
    },
    "fg": {
      "default": { "$type": "color", "$value": "{color.black}", "$description": "Primary text" },
      "secondary": { "$type": "color", "$value": "{color.grey-darker}", "$description": "Secondary text" },
      "muted": { "$type": "color", "$value": "{color.grey-dark}", "$description": "Muted text" },
      "placeholder": { "$type": "color", "$value": "{color.grey-muted}", "$description": "Placeholder / light text" },
      "inverted": { "$type": "color", "$value": "{color.white}", "$description": "Text on dark backgrounds" },
      "link": { "$type": "color", "$value": "{color.grey-darker}", "$description": "Link default" },
      "link-hover": { "$type": "color", "$value": "{color.black}", "$description": "Link hover" }
    },
    "bg": {
      "default": { "$type": "color", "$value": "{color.white}", "$description": "Page background" },
      "surface": { "$type": "color", "$value": "{color.grey-surface}", "$description": "Light / highlight sections" },
      "dark": { "$type": "color", "$value": "{color.black}", "$description": "Dark sections" },
      "navy": { "$type": "color", "$value": "{color.navy}", "$description": "Navy sections" },
      "selection": { "$type": "color", "$value": "{color.navy}", "$description": "Text selection" }
    },
    "border": {
      "default": { "$type": "color", "$value": "{color.grey}", "$description": "Default border" },
      "light": { "$type": "color", "$value": "{color.grey-light}", "$description": "Light border / form inputs" },
      "hr": { "$type": "color", "$value": "{color.grey}", "$description": "Horizontal rule" },
      "focus": { "$type": "color", "$value": "{color.navy}", "$description": "Input focus ring" }
    },
    "button": {
      "fontSize": { "$type": "dimension", "$value": "{fontSize.body-m}" },
      "fontWeight": { "$type": "fontWeight", "$value": "{fontWeight.bold}" },
      "borderRadius": { "$type": "dimension", "$value": "{borderRadius.pill}" },
      "paddingVertical": { "$type": "dimension", "$value": "{spacing.s}" },
      "paddingHorizontal": { "$type": "dimension", "$value": "{spacing.m}" },
      "textCase": { "$type": "other", "$value": "uppercase" },
      "primary": {
        "bg": { "$type": "color", "$value": "{color.white}" },
        "fg": { "$type": "color", "$value": "{color.black}" }
      },
      "secondary": {
        "bg": { "$type": "color", "$value": "rgba(0, 0, 0, 0)" },
        "fg": { "$type": "color", "$value": "{color.white}" },
        "borderColor": { "$type": "color", "$value": "{color.red}" },
        "borderWidth": { "$type": "dimension", "$value": "{borderWidth.medium}" },
        "hover-bg": { "$type": "color", "$value": "{color.red}", "$description": "Secondary hover fills red" }
      },
      "accent": {
        "bg": { "$type": "color", "$value": "{color.navy}" },
        "fg": { "$type": "color", "$value": "{color.white}" },
        "borderColor": { "$type": "color", "$value": "{color.navy}" },
        "hover-bg": { "$type": "color", "$value": "{color.navy-light}" }
      }
    },
    "input": {
      "borderColor": { "$type": "color", "$value": "{border.light}" },
      "borderRadius": { "$type": "dimension", "$value": "{borderRadius.sm}" },
      "focusBorderColor": { "$type": "color", "$value": "{color.navy}" },
      "focusShadow": {
        "$type": "boxShadow",
        "$value": { "x": "0", "y": "0", "blur": "0", "spread": "3", "color": "rgba(4, 14, 75, 0.15)", "type": "dropShadow" }
      }
    }
  }
}
